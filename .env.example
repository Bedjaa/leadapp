# Common
NODE_ENV=development
JWT_SECRET=change_me

# DB / Redis
DATABASE_URL=postgresql://postgres:postgres@db:5432/app
REDIS_URL=redis://redis:6379

# AWS S3
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=replace
AWS_SECRET_ACCESS_KEY=replace

# META (Facebook)
META_APP_ID=replace
META_APP_SECRET=replace
META_REDIRECT_URI=http://localhost:4000/api/meta/callback

# STRIPE
STRIPE_SECRET_KEY=replace
STRIPE_WEBHOOK_SECRET=replace
STRIPE_CONNECT_CLIENT_ID=replace
APP_PUBLIC_URL=http://localhost:3000

# OPENAI
OPENAI_API_KEY=replace

# SENDGRID
SENDGRID_API_KEY=replace
SENDGRID_FROM=noreply@yourapp.test

# TWILIO
TWILIO_ACCOUNT_SID=replace
TWILIO_AUTH_TOKEN=replace
TWILIO_FROM_NUMBER=+10000000000
